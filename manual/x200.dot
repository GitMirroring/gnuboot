digraph {
  subgraph cluster_southbridge {
    label="ICH9-M";
    shape="box";
    ETHERNET_CONTROLLER [label="Ethernet controller"];
  }

  # From lspci -nn:
  # 00:19.0 Ethernet controller [0200]: Intel Corporation 82567LM Gigabit
  # Network Connection [8086:10f5] (rev 03)
  ETHERNET_PHY [label="82567LM (Ethernet 10/100/1000 PHY)"];

  # From "82567 GbE Physical Layer Transceiver (PHY)" "Datasheet":
  # "The 82567 interfaces with its MAC through two interfaces: Gigabit
  # LAN Connect Interface (GLCI) and LAN Connect Interface
  # (LCI). [...] The 82567 operates using both interfaces;"
  ETHERNET_CONTROLLER -> ETHERNET_PHY [label="LCI (10/100) + GLCI (1000)"];

  # See "Crystal Specifications" in the "82567 GbE Physical Layer
  # Transceiver (PHY)" "Datasheet".
  "25 MHz, < 30ppm chrystal" -> "ETHERNET_PHY";
}
