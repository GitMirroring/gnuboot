topdir="$(realpath "$(dirname "$(dirname "$(dirname "$(dirname "$0")")")")")"
progname="resources/packages/grub/test"

. "${topdir}"/resources/scripts/misc/sysexits.sh

usage()
{
    progname="$1"

    printf "Usage: %s [options]\n\n" "${progname}"
    printf "Available options:\n"
    printf "\t-h, --help\n"
    printf "\t\tDisplay this help and exit.\n"
}

test_grub()
{
    sha512sum -c "${topdir}"/resources/packages/grub/grub.sha512
}

if [ $# -eq 1 ] && { [ "$1" = "-h" ] || [ "$1" == "--help" ] ;} ; then
    usage "${progname}"
    exit 0
elif [ $# -eq 0 ] ; then
    test_grub
else
    usage "${progname}"
    exit ${EX_USAGE}
fi
