set -e
set -u

if [ "x${DEBUG+set}" = 'xset' ] ; then
    set -v
fi

progname="./download grub"
topdir="$(realpath "$(dirname "$(dirname "$(dirname "$(dirname "$0")")")")")"

if [ $# -eq 0 ] ; then
    "${topdir}"/resources/wrapper/guix build \
               --system=i686-linux \
               grub-coreboot
elif [ $# -eq 1 ] && [ "$1" = "--help" ] ; then
    printf "Usage:\n"
    printf "\t%s            # %s\n" \
           "${progname}" \
           "Download GRUB"
    printf "\t%s --help     # %s\n" \
           "${progname}" \
           "Prints this help"
    exit 0
fi
